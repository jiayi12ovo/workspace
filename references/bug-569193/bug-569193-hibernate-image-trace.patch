+	if (hibernate_image_trace_enabled)
+		hibernate_image_trace_reset();
 	nr_copy_pages = copy_data_pages(&copy_bm, &orig_bm, &zero_bm);
 
 	/*
@@ -2063,6 +2208,8 @@ asmlinkage __visible int swsusp_save(void)
 	nr_meta_pages = DIV_ROUND_UP(nr_pages * sizeof(long), PAGE_SIZE);
 
 	pr_info("Hibernation image created (%d pages copied, %d zero pages)\n", nr_copy_pages, nr_zero_pages);
+	if (hibernate_image_trace_enabled)
+		hibernate_image_trace_print();
 
 	return 0;
 }

