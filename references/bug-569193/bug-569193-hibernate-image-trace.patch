 #endif /* CONFIG_HIGHMEM */
 
+struct hibernate_image_trace_stats {
+	u64 total;
+	u64 copied;
+	u64 zero;
+	u64 anon;
+	u64 shmem;
+	u64 mapped_file;
+	u64 file_clean;
+	u64 file_dirty;
+	u64 slab;
+	u64 pagetable;
+	u64 reserved;
+	u64 kernel_other;
+	u64 unknown;
+};
+
+static struct hibernate_image_trace_stats hib_trace_stats;
+
+static void hibernate_image_trace_reset(void)
+{
+	memset(&hib_trace_stats, 0, sizeof(hib_trace_stats));
+}
+
+static u64 hibernate_image_trace_mb(u64 pages)
+{
+	return (pages * PAGE_SIZE) / (1024 * 1024);
+}
+
+static void hibernate_image_trace_account_page(struct page *page, bool zero)
+{
+	struct address_space *mapping;
+
+	page = compound_head(page);
+
+	hib_trace_stats.total++;
+	if (zero)
+		hib_trace_stats.zero++;
+	else
+		hib_trace_stats.copied++;
+
+	if (PageReserved(page)) {
+		hib_trace_stats.reserved++;
+		return;
+	}
+
+	if (PageSlab(page)) {
+		hib_trace_stats.slab++;
+		return;
+	}
+
+	if (PageTable(page)) {
+		hib_trace_stats.pagetable++;
+		return;
+	}
+
+	if (PageAnon(page)) {
+		hib_trace_stats.anon++;
+		return;
+	}
+
+	if (PageSwapBacked(page)) {
+		hib_trace_stats.shmem++;
+		return;
+	}
+
+	mapping = page_mapping(page);
+	if (mapping) {
+		if (page_mapped(page))
+			hib_trace_stats.mapped_file++;
+		else if (PageDirty(page))
+			hib_trace_stats.file_dirty++;
+		else
+			hib_trace_stats.file_clean++;
+		return;
+	}
+
+	hib_trace_stats.kernel_other++;
+}
+
+static void hibernate_image_trace_print(void)
+{
+#define HIB_TRACE_PRINT(_name)						\
+	pr_info("  %-13s %10llu pages %8llu MB\n", #_name ":",		\
+		(unsigned long long)hib_trace_stats._name,		\
+		(unsigned long long)hibernate_image_trace_mb(		\
+			hib_trace_stats._name))
+
+	pr_info("Hibernate image page breakdown:\n");
+	HIB_TRACE_PRINT(total);
+	HIB_TRACE_PRINT(copied);
+	HIB_TRACE_PRINT(zero);
+	HIB_TRACE_PRINT(anon);
+	HIB_TRACE_PRINT(shmem);
+	HIB_TRACE_PRINT(mapped_file);
+	HIB_TRACE_PRINT(file_clean);
+	HIB_TRACE_PRINT(file_dirty);
+	HIB_TRACE_PRINT(slab);
+	HIB_TRACE_PRINT(pagetable);
+	HIB_TRACE_PRINT(reserved);
+	HIB_TRACE_PRINT(kernel_other);
+	HIB_TRACE_PRINT(unknown);
+
+#undef HIB_TRACE_PRINT
+}
+
+ssize_t hibernate_image_trace_stats_show(struct kobject *kobj,
+					 struct kobj_attribute *attr, char *buf)
+{
+	int len = 0;
+
+#define HIB_TRACE_APPEND(_name)						\
+	len += scnprintf(buf + len, PAGE_SIZE - len,			\
+			 "%-13s %10llu pages %8llu MB\n", #_name,	\
+			 (unsigned long long)hib_trace_stats._name,	\
+			 (unsigned long long)hibernate_image_trace_mb(	\
+				hib_trace_stats._name))
+
+	HIB_TRACE_APPEND(total);
+	HIB_TRACE_APPEND(copied);
+	HIB_TRACE_APPEND(zero);
+	HIB_TRACE_APPEND(anon);
+	HIB_TRACE_APPEND(shmem);
+	HIB_TRACE_APPEND(mapped_file);
+	HIB_TRACE_APPEND(file_clean);
+	HIB_TRACE_APPEND(file_dirty);
+	HIB_TRACE_APPEND(slab);
+	HIB_TRACE_APPEND(pagetable);
+	HIB_TRACE_APPEND(reserved);
+	HIB_TRACE_APPEND(kernel_other);
+	HIB_TRACE_APPEND(unknown);
+
+#undef HIB_TRACE_APPEND
+
+	return len;
+}
+
 /*
  * Copy data pages will copy all pages into pages pulled from the copy_bm.
  * If a page was entirely filled with zeros it will be marked in the zero_bm.
@@ -1459,10 +1596,16 @@ static unsigned long copy_data_pages(struct memory_bitmap *copy_bm,
