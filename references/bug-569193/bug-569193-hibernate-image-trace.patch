+}
+
+static ssize_t hibernate_image_trace_store(struct kobject *kobj,
+					   struct kobj_attribute *attr,
+					   const char *buf, size_t n)
+{
+	unsigned int val;
+
+	if (sscanf(buf, "%u", &val) != 1 || val > 1)
+		return -EINVAL;
+
+	hibernate_image_trace_enabled = val;
+	return n;
+}
